# homepad-api runtime configuration
#
# Copy this file to .env for local dev (with docker-compose), or wire each
# variable into the K8s Deployment / ConfigMap / Secret in the platform repo.

# --- core ---
PORT=8080

# --- database (Postgres) ---
# Format: postgres://user:pass@host:5432/dbname?sslmode=disable
DATABASE_URL=postgres://homepad:homepad@localhost:5432/homepad?sslmode=disable

# --- sessions ---
# 32+ random bytes; rotate to force log-out everywhere.
SESSION_SECRET=change-me-to-32-random-bytes

# --- registration policy ---
# Controls whether new accounts can self-register after bootstrap.
#   open         — anyone can register (default)
#   invite_only  — only admin can create new accounts
HOMEPAD_REGISTRATION=open

# --- gatus (cluster-internal only — never expose externally) ---
GATUS_BASE_URL=http://gatus.10.17.2.213.nip.io
